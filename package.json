{
	"name": "round-timer",
	"version": "1.6.0",
	"author": "Marc Jovaní González",
	"private": true,
	"packageManager": "pnpm@11.10.0",
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build",
		"lint": "node tools/scripts/lint/lint.mjs --max-warnings 0",
		"lint:fix": "node tools/scripts/lint/lint.mjs --fix --max-warnings 0 --verbose",
		"test": "ng test",
		"typecheck": "ng build --configuration typecheck",
		"update:deps": "sh tools/scripts/update-deps.sh",
		"git:sync": "sh tools/scripts/sync-git-main.sh",
		"pnpm:match": "node tools/scripts/match-pnpm-version.mjs",
		"pnpm:match:fix": "node tools/scripts/match-pnpm-version.mjs --fix",
		"prepare": "husky"
	},
	"dependencies": {
		"@angular/common": "22.0.6",
		"@angular/compiler": "22.0.6",
		"@angular/core": "22.0.6",
		"@angular/forms": "22.0.6",
		"@angular/platform-browser": "22.0.6",
		"@angular/router": "22.0.6",
		"@angular/service-worker": "22.0.6",
		"@ngrx/signals": "21.1.1",
		"idb": "8.0.3",
		"rxjs": "7.8.2",
		"the-new-css-reset": "1.11.3",
		"tslib": "2.8.1"
	},
	"devDependencies": {
		"@angular/build": "22.0.5",
		"@angular/cli": "22.0.5",
		"@angular/compiler-cli": "22.0.6",
		"@eslint/js": "10.0.1",
		"@faker-js/faker": "^10.5.0",
		"@semantic-release/changelog": "6.0.3",
		"@semantic-release/exec": "7.1.0",
		"@semantic-release/git": "10.0.1",
		"@stylistic/eslint-plugin": "5.10.0",
		"angular-eslint": "22.0.0",
		"commitizen": "4.3.2",
		"commitlint": "21.2.0",
		"conventional-changelog-conventionalcommits": "10.2.1",
		"cz-emoji": "1.3.2-canary.2",
		"eslint": "10.6.0",
		"eslint-plugin-import-x": "4.17.1",
		"eslint-plugin-rxjs-updated": "1.0.50",
		"eslint-plugin-sonarjs": "4.1.0",
		"eslint-plugin-unused-imports": "4.4.1",
		"globals": "17.7.0",
		"husky": "9.1.7",
		"jsdom": "29.1.1",
		"lint-staged": "17.0.8",
		"prettier": "3.9.4",
		"semantic-release": "25.0.5",
		"stylelint": "17.14.0",
		"stylelint-config-clean-order": "10.0.0",
		"stylelint-config-standard-scss": "17.0.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.63.0",
		"vitest": "4.1.10"
	}
}
