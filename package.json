{
	"name": "round-timer",
	"version": "1.4.5",
	"author": "Marc Jovaní González",
	"private": true,
	"packageManager": "pnpm@11.9.0",
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build",
		"lint": "ng lint && pnpm exec prettier --check . && pnpm exec stylelint '**/*.{css,scss}'",
		"lint:fix": "ng lint --fix && pnpm exec prettier --write . && pnpm exec stylelint --fix '**/*.{css,scss}'",
		"test": "ng test",
		"prepare": "husky",
		"update:check": "pnpm outdated",
		"update": "pnpm up --latest",
		"git:sync": "sh scripts/sync-git-main.sh",
		"pnpm:match": "node scripts/match-pnpm-version.mjs",
		"pnpm:match:fix": "node scripts/match-pnpm-version.mjs --fix"
	},
	"dependencies": {
		"@angular/animations": "^22.0.4",
		"@angular/common": "22.0.4",
		"@angular/compiler": "22.0.4",
		"@angular/core": "22.0.4",
		"@angular/forms": "22.0.4",
		"@angular/platform-browser": "22.0.4",
		"@angular/router": "22.0.4",
		"@angular/service-worker": "22.0.4",
		"@ngrx/signals": "21.1.1",
		"idb": "8.0.3",
		"rxjs": "~7.8.2",
		"the-new-css-reset": "1.11.3",
		"tslib": "2.8.1"
	},
	"devDependencies": {
		"@angular/build": "22.0.4",
		"@angular/cli": "22.0.4",
		"@angular/compiler-cli": "22.0.4",
		"@eslint/js": "10.0.1",
		"@semantic-release/changelog": "6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "10.0.1",
		"angular-eslint": "22.0.0",
		"commitizen": "4.3.2",
		"commitlint": "21.1.0",
		"conventional-changelog-conventionalcommits": "10.2.0",
		"cz-emoji": "1.3.2-canary.2",
		"eslint": "10.6.0",
		"eslint-plugin-import-x": "^4.17.1",
		"eslint-plugin-rxjs-updated": "1.0.50",
		"eslint-plugin-sonarjs": "4.1.0",
		"eslint-plugin-unused-imports": "4.4.1",
		"globals": "17.7.0",
		"husky": "9.1.7",
		"jsdom": "29.1.1",
		"lint-staged": "^17.0.8",
		"prettier": "3.9.1",
		"semantic-release": "25.0.5",
		"stylelint": "17.14.0",
		"stylelint-config-clean-order": "10.0.0",
		"stylelint-config-standard-scss": "17.0.0",
		"typescript": "~6.0.3",
		"typescript-eslint": "8.62.0",
		"vitest": "4.1.9"
	}
}
