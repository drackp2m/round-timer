{
	"name": "round-timer",
	"version": "1.4.4",
	"author": "Marc Jovaní González",
	"private": true,
	"packageManager": "pnpm@11.9.0",
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build",
		"lint": "ng lint && pnpm exec prettier --check . && pnpm exec stylelint '**/*.{css,scss}'",
		"lint:fix": "ng lint --fix && pnpm exec prettier --write . && pnpm exec stylelint --fix '**/*.{css,scss}'",
		"test": "ng test",
		"prepare": "husky",
		"update:check": "pnpm outdated",
		"update": "pnpm up --latest",
		"sync:git": "sh scripts/sync-git-with-main-branch.sh",
		"check:pnpm-sync": "node scripts/check-pnpm-version-sync.mjs"
	},
	"dependencies": {
		"@angular/animations": "^22.0.1",
		"@angular/common": "22.0.1",
		"@angular/compiler": "22.0.1",
		"@angular/core": "22.0.1",
		"@angular/forms": "22.0.1",
		"@angular/platform-browser": "22.0.1",
		"@angular/router": "22.0.1",
		"@angular/service-worker": "22.0.1",
		"@ngrx/signals": "21.1.1",
		"idb": "8.0.3",
		"rxjs": "~7.8.2",
		"the-new-css-reset": "1.11.3",
		"tslib": "2.8.1"
	},
	"devDependencies": {
		"@angular/build": "22.0.1",
		"@angular/cli": "22.0.1",
		"@angular/compiler-cli": "22.0.1",
		"@eslint/js": "10.0.1",
		"@semantic-release/changelog": "6.0.3",
		"@semantic-release/git": "10.0.1",
		"angular-eslint": "22.0.0",
		"commitizen": "4.3.2",
		"commitlint": "21.0.2",
		"conventional-changelog-conventionalcommits": "9.3.1",
		"cz-emoji": "1.3.2-canary.2",
		"eslint": "10.5.0",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-rxjs-updated": "1.0.50",
		"eslint-plugin-sonarjs": "4.0.3",
		"eslint-plugin-unused-imports": "4.4.1",
		"globals": "17.6.0",
		"husky": "9.1.7",
		"jsdom": "29.1.1",
		"lint-staged": "^17.0.8",
		"prettier": "3.8.4",
		"semantic-release": "25.0.5",
		"stylelint": "17.13.0",
		"stylelint-config-clean-order": "10.0.0",
		"stylelint-config-standard-scss": "17.0.0",
		"typescript": "~6.0.3",
		"typescript-eslint": "8.61.0",
		"vitest": "4.1.8"
	}
}
